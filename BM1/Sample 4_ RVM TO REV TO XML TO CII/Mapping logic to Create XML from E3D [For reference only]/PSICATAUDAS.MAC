NEW UWRLD /PSI-CATALOGUE-UDAS

NEW UDA /SOLI-MATERIAL-NUMBER
UDNA 'MATNUM'
ABLE 6
UTYP REAL
ELEL ADD SOLI SMTE
DFLT 0

END
NEW UDA /TUBE-WALL-THICKNESS
UDNA 'TWALL'
ABLE 4
UTYP REAL
ELEL ADD TUBD

END
NEW UDA /COMP-WALL-THICKNESS
UDNA 'CWALL'
ABLE 4
UTYP REAL
ULEN 4
ELEL ADD CMPD

END
NEW UDA /COMP-LOCAL-WEIGHT
UDNA 'PSIWEIGHT'
ABLE 6
UTYP REAL
ELEL ADD ALLP ANCI LUANCI TRANCI
DFLT 0

Savework

Compile
END
END
